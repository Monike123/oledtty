[Unit]
Description=OLEDTTY Console Mirror
Documentation=file:/usr/local/share/doc/oledtty/README.md
After=multi-user.target
After=dev-i2c-1.device
Wants=dev-i2c-1.device

[Service]
Type=simple
User=root
Group=root
ExecStart=/usr/local/bin/oledtty
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
